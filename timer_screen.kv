# timer_screen.kv
# Layout for TimerScreen (Pomodoro). timer_label and session_label
# are updated every 0.2s by refresh_ui() in timer_screen.py.

<TimerScreen>:
    MDBoxLayout:
        orientation: "vertical"
        padding: dp(24)
        spacing: dp(24)
        pos_hint: {"center_x": 0.5, "center_y": 0.5}

        MDLabel:
            id: session_label
            text: "Focus Time"
            halign: "center"
            font_style: "Title"
            role: "medium"

        MDLabel:
            id: timer_label
            text: "25:00"
            halign: "center"
            font_style: "Title"
            role: "medium"
            font_size: "48sp"   # bumped up manually, "Display" role isn't confirmed to exist in your KivyMD build

        MDBoxLayout:
            spacing: dp(16)
            adaptive_height: True
            pos_hint: {"center_x": 0.5}

            MDButton:
                style: "filled"
                on_release: root.start_timer()
                MDButtonText:
                    text: "Start"

            MDButton:
                style: "filled"
                on_release: root.pause_timer()
                MDButtonText:
                    text: "Pause"

            MDButton:
                style: "filled"
                on_release: root.reset_timer()
                MDButtonText:
                    text: "Reset"

            MDIconButton:
                icon: "cog-outline"
                on_release: root.open_timer_dialog()